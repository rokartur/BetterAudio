    "Volume keys control the forced player only when %@ is the active output device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lautstärketasten steuern den erzwungenen Player nur, wenn %@ das aktive Ausgabegerät ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volume keys control the forced player only when %@ is the active output device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las teclas de volumen controlan el reproductor forzado solo cuando %@ es el dispositivo de salida activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les touches de volume contrôlent le lecteur forcé uniquement quand %@ est l'appareil de sortie actif."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tasti del volume controllano il lettore forzato solo quando %@ è il dispositivo di uscita attivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Volumetoetsen bedienen de geforceerde speler alleen wanneer %@ het actieve uitvoerapparaat is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klawisze głośności kontrolują wymuszony odtwarzacz tylko gdy %@ jest aktywnym urządzeniem wyjściowym."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅当 %@ 是活跃输出设备时，音量键控制强制播放器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅當 %@ 是活躍輸出裝置時，音量鍵控制強制播放器。"
          }
        }
      }
    },
    "Volume keys control the forced player regardless of the active output device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lautstärketasten steuern den erzwungenen Player unabhängig vom aktiven Ausgabegerät."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Volume keys control the forced player regardless of the active output device."
          }
