    "\n\nThe transcribed text has been copied to your clipboard instead." : {
      "comment" : "Those two lines above the text should be there",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nDer transkribierte Text wurde stattdessen in die Zwischenablage kopiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nThe transcribed text has been copied to your clipboard instead."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nEl texto transcrito se ha copiado al portapapeles."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nLe texte transcrit a été copié dans votre presse-papiers à la place."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nIl testo trascritto è stato copiato negli appunti."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nDe getranscribeerde tekst is in plaats daarvan naar je klembord gekopieerd."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\nTranskrybowany tekst został skopiowany do schowka."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n转录文本已复制到剪贴板。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\n\n轉錄文本已複製到剪貼簿。"
          }
        }
      }
    },
