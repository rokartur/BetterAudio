            "state": "translated",
            "value": "切換活躍媒體播放器的隨機播放模式。"
          }
        }
      }
    },
    "Toggles silent mode, which mutes both the microphone and output simultaneously.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schaltet den Stummmodus um, der gleichzeitig Mikrofon und Ausgabe stummschaltet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggles silent mode, which mutes both the microphone and output simultaneously."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna el modo silencioso, que silencia el micrófono y la salida simultáneamente."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bascule le mode silencieux, qui coupe simultanément le microphone et la sortie."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna la modalità silenziosa, che disattiva contemporaneamente microfono e uscita."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakelt de stille modus, die zowel de microfoon als de uitvoer tegelijk dempt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącza tryb cichy, który jednocześnie wycisza mikrofon i wyjście."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换静默模式，同时静音麦克风和输出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換靜默模式，同時靜音麥克風和輸出。"
          }
        }
      }
    },
    "Toggles the microphone mute/unmute state.": {
      "localizations": {
        "de": {
          "stringUnit": {
