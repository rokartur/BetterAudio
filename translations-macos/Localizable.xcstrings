    "Aggregates quick key presses within the window and applies a single volume change. Turn off for immediate per-press adjustments." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fasst schnelle Tastendrücke innerhalb des Fensters zusammen und wendet eine einzige Lautstärkeänderung an. Deaktivieren Sie dies für sofortige Anpassungen pro Tastendruck."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggregates quick key presses within the window and applies a single volume change. Turn off for immediate per-press adjustments."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agrupa pulsaciones rápidas dentro de la ventana y aplica un solo cambio de volumen. Desactívalo para ajustes inmediatos en cada pulsación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regroupe les appuis rapides dans la fenêtre et applique un seul changement de volume. Désactivez cette option pour des ajustements immédiats à chaque appui."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Raggruppa le pressioni rapide dei tasti all'interno della finestra e applica una sola modifica del volume. Disattivalo per regolazioni immediate a ogni pressione."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bundelt snelle toetsaanslagen binnen het venster en past één volumewijziging toe. Zet dit uit voor directe aanpassingen per toetsaanslag."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grupuje szybkie naciśnięcia klawiszy w obrębie okna i stosuje jedną zmianę głośności. Wyłącz tę opcję, aby każda zmiana była stosowana natychmiast."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在窗口内聚合快速按键，并应用一次音量变化。关闭此项可在每次按键时立即调整。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在視窗內彙整快速按鍵並套用一次音量變更。關閉後每次按鍵都會立即調整。"
          }
        }
      }
    },
