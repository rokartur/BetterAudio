    "Apple SpeechTranscriber does not support your current locale yet.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber unterstützt Ihre aktuelle Sprache noch nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber does not support your current locale yet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber aún no admite tu configuración regional actual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber ne prend pas encore en charge votre langue actuelle."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber non supporta ancora la tua lingua corrente."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber ondersteunt je huidige taal nog niet."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber nie obsługuje jeszcze Twojej bieżącej lokalizacji."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber 尚不支持您当前的语言区域。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple SpeechTranscriber 尚不支持您當前的語言區域。"
          }
        }
      }
    },
    "Applies a previously saved audio routing profile, restoring all per-app volume, mute, balance, EQ, and routing settings.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wendet ein zuvor gespeichertes Audio-Routing-Profil an und stellt alle App-spezifischen Einstellungen für Lautstärke, Stummschaltung, Balance, EQ und Routing wieder her."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies a previously saved audio routing profile, restoring all per-app volume, mute, balance, EQ, and routing settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica un perfil de enrutamiento de audio guardado previamente, restaurando todos los ajustes de volumen, silencio, balance, EQ y enrutamiento por aplicación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Applique un profil de routage audio précédemment enregistré, restaurant tous les réglages de volume, sourdine, balance, EQ et routage par application."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica un profilo di routing audio salvato in precedenza, ripristinando tutte le impostazioni di volume, muto, bilanciamento, EQ e routing per app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Past een eerder opgeslagen audiorouteringsprofiel toe en herstelt alle per-app volume-, demping-, balans-, EQ- en routeringsinstellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stosuje wcześniej zapisany profil routingu audio, przywracając wszystkie ustawienia głośności, wyciszenia, balansu, EQ i routingu dla poszczególnych aplikacji."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用先前保存的音频路由配置，恢复所有按应用的音量、静音、平衡、均衡器和路由设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用先前保存的音訊路由配置，恢復所有按應用的音量、靜音、平衡、均衡器和路由設置。"
          }
        }
      }
    },
    "Applies an equalizer preset to a specific application's audio output.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wendet eine Equalizer-Voreinstellung auf die Audioausgabe einer bestimmten Anwendung an."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies an equalizer preset to a specific application's audio output."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica un preset de ecualizador a la salida de audio de una aplicación específica."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Applique un préréglage d'égaliseur à la sortie audio d'une application spécifique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica un preset dell'equalizzatore all'uscita audio di un'applicazione specifica."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Past een equalizerpreset toe op de audio-uitvoer van een specifieke applicatie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stosuje ustawienie wstępne korektora do wyjścia audio wybranej aplikacji."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将均衡器预设应用于特定应用的音频输出。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將均衡器預設應用于特定應用的音訊輸出。"
          }
        }
      }
    },
    "Applies when the device-specific reset button is visible.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gilt, wenn die gerätespezifische Reset-Schaltfläche sichtbar ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies when the device-specific reset button is visible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se aplica cuando el botón de restablecimiento específico del dispositivo está visible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "S’applique lorsque le bouton de réinitialisation spécifique à l’appareil est visible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si applica quando il pulsante di ripristino specifico del dispositivo è visibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wordt toegepast wanneer de apparaatspecifieke resetknop zichtbaar is."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Działa, gdy widoczny jest przycisk resetu dla tego urządzenia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当设备专用的重置按钮可见时适用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "當裝置專用的重設按鈕可見時適用。"
          }
        }
      }
    },
    "Apply a 10-band equalizer whenever audio is routed to this device. Changes take effect immediately.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "10-Band-Equalizer anwenden, wenn Audio an dieses Gerät weitergeleitet wird. Änderungen werden sofort wirksam."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apply a 10-band equalizer whenever audio is routed to this device. Changes take effect immediately."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica un ecualizador de 10 bandas cuando el audio se enrute a este dispositivo. Los cambios surten efecto de inmediato."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Applique un égaliseur 10 bandes lorsque l'audio est routé vers cet appareil. Les modifications prennent effet immédiatement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Applica un equalizzatore a 10 bande ogni volta che l'audio viene instradato verso questo dispositivo. Le modifiche hanno effetto immediato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Past een 10-bands equalizer toe wanneer audio naar dit apparaat wordt geleid. Wijzigingen worden direct toegepast."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zastosuj 10-pasmowy korektor, gdy dźwięk jest kierowany do tego urządzenia. Zmiany są stosowane natychmiast."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每当音频被路由到此设备时应用 10 段均衡器。更改立即生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每當音訊路由到此裝置時套用 10 段等化器。變更立即生效。"
          }
        }
      }
    },
