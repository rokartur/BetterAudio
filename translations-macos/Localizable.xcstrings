    "Merge the cloud copy into this Mac and keep local-only changes when possible.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Cloud-Kopie in diesen Mac zusammenführen und lokale Änderungen nach Möglichkeit behalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Merge the cloud copy into this Mac and keep local-only changes when possible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusiona la copia de la nube en este Mac y conserva los cambios locales cuando sea posible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusionner la copie cloud dans ce Mac et conserver les modifications locales lorsque possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Unisci la copia cloud a questo Mac e conserva le modifiche solo locali quando possibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voeg de cloudkopie samen op deze Mac en behoud lokale wijzigingen waar mogelijk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scal kopię w chmurze z tym Makiem i zachowaj lokalne zmiany, gdy to możliwe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将云端副本合并到这台 Mac，并尽可能保留仅本地的更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將雲端副本合併到這台 Mac，並盡可能保留僅本機的變更。"
          }
        }
      }
    },
