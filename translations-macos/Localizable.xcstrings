    "This releases Apple Speech assets for %@. Shared system assets may remain if used by other apps.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermit werden Apple Speech-Ressourcen für %@ freigegeben. Gemeinsame Systemressourcen können erhalten bleiben, wenn sie von anderen Apps verwendet werden."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This releases Apple Speech assets for %@. Shared system assets may remain if used by other apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto libera los recursos de Apple Speech para %@. Los recursos compartidos del sistema pueden permanecer si los usan otras apps."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ceci libère les ressources Apple Speech pour %@. Les ressources système partagées peuvent rester si elles sont utilisées par d'autres applications."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo rilascia le risorse Apple Speech per %@. Le risorse di sistema condivise possono rimanere se utilizzate da altre app."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dit geeft Apple Speech-bronnen vrij voor %@. Gedeelde systeembronnen kunnen blijven als ze door andere apps worden gebruikt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "To zwalnia zasoby Apple Speech dla %@. Współdzielone zasoby systemowe mogą pozostać, jeśli są używane przez inne aplikacje."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将释放 %@ 的 Apple Speech 资源。如果其他应用使用共享的系统资源，这些资源可能会保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將釋放 %@ 的 Apple Speech 資源。如果其他應用使用共享的系統資源，這些資源可能會保留。"
          }
        }
      }
    },
    "This removes downloaded files for %@.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Hiermit werden heruntergeladene Dateien für %@ entfernt."
