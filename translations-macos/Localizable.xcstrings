    "Use selected apps as triggers for meeting device switching": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ausgewählte Apps als Auslöser für das Wechseln der Audiogeräte nutzen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use selected apps as triggers for meeting device switching"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usar las apps seleccionadas como activadores para cambiar los dispositivos de audio"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utiliser les apps sélectionnées comme déclencheurs pour changer les appareils audio"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa le app selezionate per attivare il cambio dei dispositivi audio"
          }
        },
        "nl": {
          "stringUnit": {
