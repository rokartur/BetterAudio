    "Toggles shuffle mode for the active media player.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schaltet die Zufallswiedergabe für den aktiven Media-Player um."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggles shuffle mode for the active media player."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna el modo aleatorio del reproductor multimedia activo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bascule le mode de lecture aléatoire pour le lecteur multimédia actif."
          }
        },
        "it": {
          "stringUnit": {
