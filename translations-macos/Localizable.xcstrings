    "Lower values reduce audio/video desync but may cause glitches on slower devices.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Niedrigere Werte reduzieren Audio-/Videoversatz, können aber bei langsameren Geräten zu Aussetzern führen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lower values reduce audio/video desync but may cause glitches on slower devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los valores más bajos reducen el desfase entre audio y vídeo, pero pueden causar fallos en dispositivos más lentos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des valeurs plus basses réduisent la désynchronisation audio/vidéo mais peuvent causer des coupures sur les appareils lents."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Valori più bassi riducono la desincronizzazione audio/video ma possono causare problemi su dispositivi più lenti."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Lagere waarden verminderen audio-/videosynchronisatieproblemen maar kunnen storingen veroorzaken op tragere apparaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niższe wartości redukują desynchronizację audio/wideo, ale mogą powodować zakłócenia na wolniejszych urządzeniach."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "较低的值可减少音视频不同步，但在较慢的设备上可能出现卡顿。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "較低的值可減少音訊/視訊不同步，但在較慢的裝置上可能出現卡頓。"
          }
        }
      }
    },
    "macOS handles volume keys. BetterAudio won’t control the forced player.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS steuert die Lautstärketasten. BetterAudio kontrolliert den erzwungenen Player nicht."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS handles volume keys. BetterAudio won’t control the forced player."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS controla las teclas de volumen. BetterAudio no controlará el reproductor forzado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS gère les touches de volume. BetterAudio ne contrôlera pas le lecteur forcé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS gestisce i tasti del volume. BetterAudio non controllerà il lettore forzato."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS beheert de volumetoetsen. BetterAudio zal de geforceerde speler niet bedienen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS obsługuje klawisze głośności. BetterAudio nie będzie kontrolować wymuszonego odtwarzacza."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 处理音量键。BetterAudio 将不会控制强制播放器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS 處理音量鍵。BetterAudio 將不會控制強制播放器。"
          }
        }
      }
    },
