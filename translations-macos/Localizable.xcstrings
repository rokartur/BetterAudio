    "BetterAudio is ready to enhance your audio experience. Click the menu bar icon to get started.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio ist bereit, Ihr Audioerlebnis zu verbessern. Klicken Sie auf das Symbol in der Menüleiste, um loszulegen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio is ready to enhance your audio experience. Click the menu bar icon to get started."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio está listo para mejorar tu experiencia de audio. Haz clic en el icono de la barra de menús para comenzar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio est prêt à améliorer votre expérience audio. Cliquez sur l'icône dans la barre de menus pour commencer."
          }
        },
        "it": {
          "stringUnit": {
