    "Premium feature — keep volumes, profiles, HUD positions, dictation, and shortcut exclusions in lockstep across your Macs.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Premiumfunktion — hält Lautstärken, Profile, HUD-Positionen, Diktat und Tastenkürzel-Ausnahmen auf deinen Macs synchron."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium feature — keep volumes, profiles, HUD positions, dictation, and shortcut exclusions in lockstep across your Macs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Función Premium — mantiene volúmenes, perfiles, posiciones de HUD, dictado y exclusiones de atajos sincronizados entre tus Macs."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fonction Premium — gardez volumes, profils, positions du HUD, dictée et exclusions de raccourcis synchronisés entre vos Macs."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Funzione Premium — mantieni volumi, profili, posizioni HUD, dettatura ed esclusioni delle scorciatoie sincronizzati tra i tuoi Mac."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Premiumfunctie — houd volumes, profielen, HUD-posities, dicteren en snelkoppelinguitsluitingen gesynchroniseerd tussen je Macs."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Funkcja Premium — synchronizuje głośności, profile, pozycje HUD, dyktowanie i wykluczenia skrótów między Twoimi Macami."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium 功能 — 让您的 Mac 之间的音量、配置、HUD 位置、听写和快捷键排除项保持同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium 功能 — 讓您的 Mac 之間的音量、設定檔、HUD 位置、聽寫和快捷鍵排除項目保持同步。"
          }
        }
      }
    },
