          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wykryto problem bezpieczeństwa. Funkcje premium zostały tymczasowo wyłączone. Uruchom ponownie aplikację."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "检测到安全问题。高级功能已被暂时禁用。请重新启动应用程序。"
