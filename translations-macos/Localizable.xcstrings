          }
        }
      }
    },
    "Use the recording shortcut to capture audio.\nRecordings will appear here for playback and transcription.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie das Aufnahme-Tastaturkürzel, um Audio aufzunehmen.\nAufnahmen erscheinen hier zur Wiedergabe und Transkription."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the recording shortcut to capture audio.\nRecordings will appear here for playback and transcription."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa el atajo de grabación para capturar audio.\nLas grabaciones aparecerán aquí para reproducción y transcripción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez le raccourci d'enregistrement pour capturer l'audio.\nLes enregistrements apparaîtront ici pour la lecture et la transcription."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la scorciatoia di registrazione per catturare l'audio.\nLe registrazioni appariranno qui per la riproduzione e la trascrizione."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Gebruik de opnamesneltoets om audio vast te leggen.\nOpnames verschijnen hier voor afspelen en transcriptie."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Użyj skrótu nagrywania, aby przechwycić dźwięk.\nNagrania pojawią się tutaj do odtwarzania i transkrypcji."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用录音快捷键捕获音频。\n录音将在此处显示以供播放和转录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用錄音快捷鍵捕獲音訊。\n錄音將在此處顯示以供播放和轉錄。"
          }
        }
      }
    },
    "Uses the units selected in General > Display units": {
