    "A security issue has been detected. Premium features have been temporarily disabled. Please restart the application." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Sicherheitsproblem wurde erkannt. Premium-Funktionen wurden vorübergehend deaktiviert. Bitte starten Sie die Anwendung neu."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A security issue has been detected. Premium features have been temporarily disabled. Please restart the application."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se ha detectado un problema de seguridad. Las funciones premium se han desactivado temporalmente. Por favor, reinicia la aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un problème de sécurité a été détecté. Les fonctionnalités premium ont été temporairement désactivées. Veuillez redémarrer l'application."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È stato rilevato un problema di sicurezza. Le funzioni premium sono state temporaneamente disabilitate. Riavvia l'applicazione."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
