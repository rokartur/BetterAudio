    "Are you sure you want to deactivate the license on this device? You can activate it again on this or another computer.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Möchten Sie die Lizenz auf diesem Gerät wirklich deaktivieren? Sie können sie auf diesem oder einem anderen Computer erneut aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to deactivate the license on this device? You can activate it again on this or another computer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Estás seguro de que quieres desactivar la licencia en este dispositivo? Puedes volver a activarla en este u otro ordenador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Êtes-vous sûr de vouloir désactiver la licence sur cet appareil ? Vous pouvez la réactiver sur cet ordinateur ou un autre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sei sicuro di voler disattivare la licenza su questo dispositivo? Puoi attivarla di nuovo su questo o su un altro computer."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Weet je zeker dat je de licentie op dit apparaat wilt deactiveren? Je kunt deze opnieuw activeren op deze of een andere computer."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Czy na pewno chcesz dezaktywować licencję na tym urządzeniu? Możesz aktywować ją ponownie na tym lub innym komputerze."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要在此设备上停用许可证吗？您可以在此计算机或其他计算机上重新激活。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要在此裝置上停用許可證嗎？您可以在此計算機或其他計算機上重新啟用。"
          }
        }
      }
    },
