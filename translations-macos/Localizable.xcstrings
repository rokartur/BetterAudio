    "BetterAudio needs Accessibility access to control media keys, monitor audio devices, and provide system-wide shortcuts." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio benötigt Bedienungshilfen-Zugriff, um Medientasten zu steuern, Audiogeräte zu überwachen und systemweite Kurzbefehle bereitzustellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio needs Accessibility access to control media keys, monitor audio devices, and provide system-wide shortcuts."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio necesita acceso de accesibilidad para controlar las teclas multimedia, monitorear dispositivos de audio y proporcionar atajos del sistema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio a besoin de l'accès Accessibilité pour contrôler les touches multimédia, surveiller les appareils audio et fournir des raccourcis système."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio necessita dell'accesso accessibilità per controllare i tasti multimediali, monitorare i dispositivi audio e fornire scorciatoie di sistema."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio heeft toegankelijkheidstoegang nodig om mediatoetsen te bedienen, audioapparaten te bewaken en systeembrede sneltoetsen te bieden."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio potrzebuje dostępu do Dostępności, aby kontrolować klawisze multimedialne, monitorować urządzenia audio i zapewniać skróty systemowe."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio 需要辅助功能访问权限来控制媒体键、监控音频设备并提供系统级快捷键。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "BetterAudio 需要輔助功能訪問權限來控制媒體鍵、監控音訊裝置並提供系統級快捷鍵。"
          }
        }
      }
    },
