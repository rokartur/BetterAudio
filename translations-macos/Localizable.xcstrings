    "Let's set up a few things to get the most out of BetterAudio.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass uns ein paar Dinge einrichten, um BetterAudio optimal zu nutzen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Let's set up a few things to get the most out of BetterAudio."
