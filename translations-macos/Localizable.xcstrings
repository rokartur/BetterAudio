    "Choose one output normally. Hold Shift while selecting from the list to add or remove devices for multi-output.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie normalerweise einen Ausgang. Halten Sie beim Auswählen aus der Liste die Umschalttaste gedrückt, um Geräte für Mehrfachausgabe hinzuzufügen oder zu entfernen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose one output normally. Hold Shift while selecting from the list to add or remove devices for multi-output."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige una salida normalmente. Mantén pulsada la tecla Mayús al seleccionar en la lista para añadir o quitar dispositivos para salida múltiple."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez normalement une seule sortie. Maintenez Maj enfoncé lors de la sélection dans la liste pour ajouter ou retirer des appareils pour la sortie multiple."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli normalmente una sola uscita. Tieni premuto Maiusc mentre selezioni dall'elenco per aggiungere o rimuovere dispositivi per l'uscita multipla."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies normaal één uitgang. Houd Shift ingedrukt terwijl je uit de lijst selecteert om apparaten voor multi-output toe te voegen of te verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwykle wybierz jedno wyjście. Przytrzymaj Shift podczas wybierania z listy, aby dodać lub usunąć urządzenia dla trybu wielowyjściowego."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通常请选择一个输出。按住 Shift 并从列表中选择，以添加或移除多输出设备。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "通常請選擇一個輸出。從清單中選取時按住 Shift，可加入或移除多輸出裝置。"
          }
        }
      }
    },
