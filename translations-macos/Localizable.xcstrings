    "\"%@\" disconnected. %lld app(s) switched to %@": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„%1$@\" getrennt. %2$lld App(s) auf %3$@ umgeschaltet"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" disconnected. %2$lld app(s) switched to %3$@"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" desconectado. %2$lld app(s) cambiaron a %3$@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" déconnecté. %2$lld application(s) basculée(s) vers %3$@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" disconnesso. %2$lld app passate a %3$@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\" losgekoppeld. %2$lld app(s) overgeschakeld naar %3$@"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "„%1$@\" rozłączono. %2$lld aplikacji przełączono na %3$@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%1$@\"已断开连接。%2$lld 个应用已切换到 %3$@"
