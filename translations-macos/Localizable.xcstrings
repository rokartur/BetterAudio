    "Connection blocked. If you're using a VPN or corporate network, try disabling it temporarily." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbindung blockiert. Wenn Sie ein VPN oder Firmennetzwerk verwenden, deaktivieren Sie es vorübergehend."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connection blocked. If you're using a VPN or corporate network, try disabling it temporarily."
          }
        },
        "es" : {
          "stringUnit" : {
