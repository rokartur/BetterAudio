            "state" : "translated",
            "value" : "Geräte werden beim Wechseln in Prioritätsreihenfolge ausgewählt%@. Zum Neuordnen ziehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Devices are selected in priority order when cycling%@. Drag to reorder."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los dispositivos se seleccionan en orden de prioridad al alternar%@. Arrastra para reordenar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les appareils sont sélectionnés par ordre de priorité lors du cycle%@. Glissez pour réorganiser."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I dispositivi vengono selezionati in ordine di priorità durante il cambio%@. Trascina per riordinare."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Apparaten worden in prioriteitsvolgorde geselecteerd bij het wisselen%@. Sleep om te herschikken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Urządzenia są wybierane w kolejności priorytetów podczas przełączania%@. Przeciągnij, aby zmienić kolejność."
          }
