    "Keep BetterAudio preferences and per-app audio in sync between your Macs. Encrypted, private, and only on your devices.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Halte BetterAudio-Einstellungen und Per-App-Audio zwischen deinen Macs synchron. Verschlüsselt, privat und nur auf deinen Geräten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep BetterAudio preferences and per-app audio in sync between your Macs. Encrypted, private, and only on your devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén las preferencias de BetterAudio y el audio por app sincronizados entre tus Macs. Cifrado, privado y solo en tus dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez les préférences BetterAudio et l’audio par app synchronisés entre vos Macs. Chiffré, privé et uniquement sur vos appareils."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni sincronizzate le preferenze BetterAudio e l’audio per app tra i tuoi Mac. Crittografato, privato e solo sui tuoi dispositivi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd BetterAudio-voorkeuren en audio per app gesynchroniseerd tussen je Macs. Versleuteld, privé en alleen op je apparaten."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Synchronizuj preferencje BetterAudio i dźwięk aplikacji między swoimi Macami. Szyfrowane, prywatne i tylko na Twoich urządzeniach."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在您的 Mac 之间同步 BetterAudio 偏好设置和按应用音频。加密、私密，且仅在您的设备上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在您的 Mac 之間同步 BetterAudio 偏好設定和各 App 音訊。加密、私密，且僅在您的裝置上。"
          }
        }
      }
    },
    "Keep BetterAudio running in your menu bar whenever you start your Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lass BetterAudio bei jedem Mac-Start in der Menüleiste laufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep BetterAudio running in your menu bar whenever you start your Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantén BetterAudio ejecutándose en la barra de menús cada vez que inicies tu Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez BetterAudio dans votre barre de menus à chaque démarrage de votre Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mantieni BetterAudio in esecuzione nella barra dei menu ogni volta che avvii il Mac."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Houd BetterAudio actief in je menubalk wanneer je je Mac opstart."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Uruchamiaj BetterAudio na pasku menu przy każdym starcie Maca."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每次启动 Mac 时保持 BetterAudio 在菜单栏中运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每次啟動 Mac 時保持 BetterAudio 在菜單欄中運行。"
          }
        }
      }
    },
