            "value": "Ein neuer BetterAudio-Build **%@** ist verfügbar — Sie verwenden einen älteren Build."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A new build of BetterAudio **%@** is available — you have an older build."
