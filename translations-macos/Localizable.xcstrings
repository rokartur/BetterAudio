    "Applies a previously saved audio routing profile, restoring all per-app volume, mute, balance, EQ, and routing settings." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wendet ein zuvor gespeichertes Audio-Routing-Profil an und stellt alle App-spezifischen Einstellungen für Lautstärke, Stummschaltung, Balance, EQ und Routing wieder her."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies a previously saved audio routing profile, restoring all per-app volume, mute, balance, EQ, and routing settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplica un perfil de enrutamiento de audio guardado previamente, restaurando todos los ajustes de volumen, silencio, balance, EQ y enrutamiento por aplicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applique un profil de routage audio précédemment enregistré, restaurant tous les réglages de volume, sourdine, balance, EQ et routage par application."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applica un profilo di routing audio salvato in precedenza, ripristinando tutte le impostazioni di volume, muto, bilanciamento, EQ e routing per app."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Past een eerder opgeslagen audiorouteringsprofiel toe en herstelt alle per-app volume-, demping-, balans-, EQ- en routeringsinstellingen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stosuje wcześniej zapisany profil routingu audio, przywracając wszystkie ustawienia głośności, wyciszenia, balansu, EQ i routingu dla poszczególnych aplikacji."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "应用先前保存的音频路由配置，恢复所有按应用的音量、静音、平衡、均衡器和路由设置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "應用先前保存的音訊路由配置，恢復所有按應用的音量、靜音、平衡、均衡器和路由設置。"
          }
        }
      }
    },
    "Applies an equalizer preset to a specific application's audio output." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wendet eine Equalizer-Voreinstellung auf die Audioausgabe einer bestimmten Anwendung an."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applies an equalizer preset to a specific application's audio output."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aplica un preset de ecualizador a la salida de audio de una aplicación específica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applique un préréglage d'égaliseur à la sortie audio d'une application spécifique."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Applica un preset dell'equalizzatore all'uscita audio di un'applicazione specifica."
