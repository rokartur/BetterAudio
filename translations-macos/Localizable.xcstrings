    "Sets the left/right stereo balance for a specific application. -100 = full left, 0 = center, 100 = full right.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Legt die Links/Rechts-Stereobalance für eine bestimmte Anwendung fest. -100 = ganz links, 0 = Mitte, 100 = ganz rechts."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sets the left/right stereo balance for a specific application. -100 = full left, 0 = center, 100 = full right."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Establece el balance estéreo izquierda/derecha de una aplicación específica. -100 = totalmente a la izquierda, 0 = centro, 100 = totalmente a la derecha."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définit la balance stéréo gauche/droite pour une application spécifique. -100 = tout à gauche, 0 = centre, 100 = tout à droite."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Imposta il bilanciamento stereo sinistro/destro di un'applicazione specifica. -100 = tutto a sinistra, 0 = centro, 100 = tutto a destra."
          }
