    "%@ requires %@ access to work properly." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ benötigt %2$@-Zugriff, um ordnungsgemäß zu funktionieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ requires %2$@ access to work properly."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ requiere acceso a %2$@ para funcionar correctamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ nécessite l'accès %2$@ pour fonctionner correctement."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ richiede l'accesso a %2$@ per funzionare correttamente."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ heeft %2$@-toegang nodig om goed te werken."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@ wymaga dostępu do %2$@, aby działać prawidłowo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%1$@需要%2$@访问权限才能正常工作。"
