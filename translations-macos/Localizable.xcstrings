            "value": "BetterAudio jest gotowy, aby ulepszyć Twoje wrażenia dźwiękowe. Kliknij ikonę na pasku menu, aby rozpocząć."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio 已准备好提升您的音频体验。点击菜单栏图标开始使用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
