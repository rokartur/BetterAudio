    "If a toggle matches the global setting, BetterAudio will keep using the global default instead of saving a device-specific override.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn ein Schalter der globalen Einstellung entspricht, verwendet BetterAudio weiterhin die globale Standardeinstellung, anstatt eine gerätespezifische Überschreibung zu speichern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If a toggle matches the global setting, BetterAudio will keep using the global default instead of saving a device-specific override."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un interruptor coincide con la configuración global, BetterAudio seguirá usando el valor predeterminado global en lugar de guardar una anulación específica del dispositivo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si un interrupteur correspond au réglage global, BetterAudio continuera d’utiliser la valeur par défaut globale au lieu d’enregistrer une substitution spécifique à l’appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se un interruttore corrisponde all'impostazione globale, BetterAudio continuerà a usare il valore predefinito globale invece di salvare una sostituzione specifica del dispositivo."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als een schakelaar overeenkomt met de globale instelling, blijft BetterAudio de globale standaard gebruiken in plaats van een apparaatspecifieke overschrijving op te slaan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli przełącznik odpowiada ustawieniu globalnemu, BetterAudio nadal będzie używać ustawienia globalnego zamiast zapisywać nadpisanie dla tego urządzenia."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果某个开关与全局设置一致，BetterAudio 将继续使用全局默认值，而不会保存设备专用覆盖。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果某個開關與全域設定一致，BetterAudio 將繼續使用全域預設值，而不會儲存裝置專用覆寫。"
          }
        }
      }
    },
