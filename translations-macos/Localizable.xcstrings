        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio wykrył nietypową konfigurację. Jeśli wystąpią nieoczekiwane zachowania, uruchom aplikację ponownie."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio 检测到异常配置。如果出现意外行为，请重新启动应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio 偵測到異常設定。如果出現非預期行為，請重新啟動應用程式。"
          }
        }
      }
    },
    "BetterAudio has been updated to version %@.\n\nThe app needs to restart to apply the update.": {
      "localizations": {
