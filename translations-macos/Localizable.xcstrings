    "See exactly which preferences sync via iCloud and which stay per-Mac.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Genau ansehen, welche Einstellungen über iCloud synchronisiert werden und welche pro Mac bleiben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See exactly which preferences sync via iCloud and which stay per-Mac."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ve exactamente qué preferencias se sincronizan con iCloud y cuáles permanecen en cada Mac."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voyez exactement quelles préférences se synchronisent via iCloud et lesquelles restent propres à chaque Mac."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Vedi esattamente quali preferenze si sincronizzano tramite iCloud e quali restano su ogni Mac."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zie precies welke voorkeuren via iCloud synchroniseren en welke per Mac blijven."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zobacz dokładnie, które preferencje są synchronizowane przez iCloud, a które pozostają na danym Macu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "准确查看哪些偏好设置会通过 iCloud 同步，哪些会保留在每台 Mac 本地。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "準確查看哪些偏好設定會透過 iCloud 同步，哪些會保留在各台 Mac 本機。"
          }
        }
      }
    },
