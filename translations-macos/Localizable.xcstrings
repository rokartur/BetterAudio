    "keyboard_shortcut_reassign_message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn Sie fortfahren, wird das Tastenkürzel von der anderen Funktion entfernt und dieser zugewiesen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you continue, the shortcut will be removed from the other function and assigned to this one."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si continúas, el atajo se eliminará de la otra función y se asignará a esta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous continuez, le raccourci sera retiré de l’autre fonction et attribué à celle-ci."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Se continui, la scorciatoia verrà rimossa dall’altra funzione e assegnata a questa."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Als u doorgaat, wordt de sneltoets van de andere functie verwijderd en aan deze toegewezen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jeśli kontynuujesz, skrót zostanie usunięty z drugiej funkcji i przypisany do tej."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果继续，快捷键将从其他功能中移除并分配给此功能。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如果繼續，快捷鍵將從其他功能中移除並分配給此功能。"
          }
        }
      }
    },
