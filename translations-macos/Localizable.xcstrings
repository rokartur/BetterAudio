    "Force mode was turned off after Accessibility permission was lost. Re-enable it once you add BetterAudio back to Accessibility.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Force-Modus wurde deaktiviert, nachdem die Bedienungshilfen-Berechtigung verloren ging. Aktivieren Sie ihn erneut, sobald Sie BetterAudio wieder zu den Bedienungshilfen hinzugefügt haben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Force mode was turned off after Accessibility permission was lost. Re-enable it once you add BetterAudio back to Accessibility."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El modo forzado se desactivó después de perder el permiso de Accesibilidad. Vuelve a activarlo cuando añadas BetterAudio de nuevo a Accesibilidad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le mode forcé a été désactivé après la perte de l’autorisation d’Accessibilité. Réactivez-le une fois BetterAudio rajouté à Accessibilité."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La modalità forzata è stata disattivata dopo la perdita dell'autorizzazione Accessibilità. Riattivala una volta aggiunto di nuovo BetterAudio ad Accessibilità."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De geforceerde modus is uitgeschakeld nadat de Toegankelijkheidsmachtiging verloren ging. Schakel hem opnieuw in zodra je BetterAudio weer aan Toegankelijkheid toevoegt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryb wymuszony został wyłączony po utracie uprawnienia Ułatwień dostępu. Włącz go ponownie, gdy dodasz BetterAudio z powrotem do Ułatwień dostępu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在辅助功能权限丢失后，强制模式已被关闭。请在重新将 BetterAudio 添加到辅助功能后再次启用它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "失去輔助使用權限後，強制模式已被關閉。請在重新將 BetterAudio 加回輔助使用後再次啟用。"
          }
        }
      }
    },
