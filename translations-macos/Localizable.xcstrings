    "Default controls for input devices in the menu panel. Per-device settings override these." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardsteuerungen für Eingabegeräte im Menüpanel. Gerätespezifische Einstellungen haben Vorrang."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Default controls for input devices in the menu panel. Per-device settings override these."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controles predeterminados para dispositivos de entrada en el panel del menú. La configuración por dispositivo tiene prioridad."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Commandes par défaut des périphériques d’entrée dans le panneau de menu. Les réglages par périphérique priment."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Controlli predefiniti per i dispositivi di input nel pannello del menu. Le impostazioni per dispositivo hanno la precedenza."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standaardbediening voor invoerapparaten in het menupaneel. Instellingen per apparaat hebben voorrang."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
