        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stelt de links/rechts-stereobalans in voor een specifieke applicatie. -100 = helemaal links, 0 = midden, 100 = helemaal rechts."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ustawia balans stereo lewo/prawo dla wybranej aplikacji. -100 = pełny lewy, 0 = środek, 100 = pełny prawy."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "设置特定应用的左右立体声平衡。-100 = 最左，0 = 居中，100 = 最右。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
