    },
    "BetterAudio never syncs your license, audio recordings, or audio device selections.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio synchronisiert niemals deine Lizenz, Audioaufnahmen oder Audiogeräteauswahl."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio never syncs your license, audio recordings, or audio device selections."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "BetterAudio nunca sincroniza tu licencia, grabaciones de audio ni selecciones de dispositivos de audio."
          }
        },
        "fr": {
