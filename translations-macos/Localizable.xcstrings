          }
        }
      }
    },
    "Toggles whether BetterAudio intercepts media keys (play/pause, next, previous) and routes them to a specific player.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schaltet um, ob BetterAudio Medientasten (Play/Pause, Weiter, Zurück) abfängt und an einen bestimmten Player weiterleitet."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggles whether BetterAudio intercepts media keys (play/pause, next, previous) and routes them to a specific player."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna si BetterAudio intercepta las teclas multimedia (reproducir/pausar, siguiente, anterior) y las dirige a un reproductor específico."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bascule l'interception des touches multimédia (lecture/pause, suivant, précédent) par BetterAudio et leur routage vers un lecteur spécifique."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna se BetterAudio intercetta i tasti multimediali (play/pausa, successivo, precedente) e li indirizza a un lettore specifico."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakelt of BetterAudio mediatoetsen (afspelen/pauzeren, volgende, vorige) onderschept en naar een specifieke speler routeert."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącza, czy BetterAudio przechwytuje klawisze multimedialne (odtwarzanie/pauza, następny, poprzedni) i przekierowuje je do wybranego odtwarzacza."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换 BetterAudio 是否拦截媒体键（播放/暂停、下一曲、上一曲）并将其路由到特定播放器。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換 BetterAudio 是否攔截媒體鍵（播放/暫停、下一曲、上一曲）並將其路由到特定播放器。"
          }
        }
      }
    },
    "Toggles whether F11/F12 volume keys control the system volume or the media player volume.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schaltet um, ob die Lautstärketasten F11/F12 die Systemlautstärke oder die Media-Player-Lautstärke steuern."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggles whether F11/F12 volume keys control the system volume or the media player volume."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna si las teclas de volumen F11/F12 controlan el volumen del sistema o el del reproductor multimedia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bascule si les touches de volume F11/F12 contrôlent le volume système ou le volume du lecteur multimédia."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Alterna se i tasti volume F11/F12 controllano il volume di sistema o il volume del lettore multimediale."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakelt of de F11/F12-volumetoetsen het systeemvolume of het mediaspelervolume regelen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przełącza, czy klawisze głośności F11/F12 sterują głośnością systemową czy głośnością odtwarzacza multimedialnego."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换 F11/F12 音量键控制系统音量还是媒体播放器音量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換 F11/F12 音量鍵控制系統音量還是媒體播放器音量。"
          }
        }
      }
    },
