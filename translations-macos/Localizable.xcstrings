    "Merges the latest BetterAudio settings from iCloud with the settings on this Mac. Local-only changes are preserved when possible.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Führt die neuesten BetterAudio-Einstellungen aus iCloud mit den Einstellungen auf diesem Mac zusammen. Nur lokale Änderungen bleiben nach Möglichkeit erhalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Merges the latest BetterAudio settings from iCloud with the settings on this Mac. Local-only changes are preserved when possible."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusiona los ajustes más recientes de BetterAudio desde iCloud con los ajustes de este Mac. Los cambios solo locales se conservan cuando es posible."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fusionne les derniers réglages BetterAudio d’iCloud avec les réglages de ce Mac. Les modifications locales uniquement sont conservées lorsque possible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Unisce le impostazioni BetterAudio più recenti da iCloud con quelle su questo Mac. Le modifiche solo locali vengono conservate quando possibile."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Voegt de nieuwste BetterAudio-instellingen uit iCloud samen met de instellingen op deze Mac. Alleen lokale wijzigingen blijven behouden waar mogelijk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Scala najnowsze ustawienia BetterAudio z iCloud z ustawieniami na tym Macu. Zmiany tylko lokalne są zachowywane, gdy to możliwe."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将 iCloud 中最新的 BetterAudio 设置与这台 Mac 上的设置合并。仅本地的更改会尽可能保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "將 iCloud 中最新的 BetterAudio 設定與這台 Mac 上的設定合併。僅本機的變更會盡可能保留。"
          }
        }
      }
    },
